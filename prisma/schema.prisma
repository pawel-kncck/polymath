// Prisma schema for Polymath learning platform
//
// Scope: user-specific data only. Learning content (modules + items) lives
// in the repo under `src/content/` so it's version-controlled and travels
// with deploys. The DB stores: users, auth sessions, and quiz results.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// Auth.js Required Models
// ============================================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String?
  role          String    @default("STUDENT") // "ADMIN" or "STUDENT"
  // Per-user allow-list of module ids the student can access. Admins bypass
  // this check entirely. Empty array = no modules visible (admin must grant).
  accessibleModuleIds String[]  @default([])
  accounts      Account[]
  sessions      Session[]
  results       Result[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// Polymath Application Models
// ============================================

// Result — tracks quiz performance for analytics.
// `moduleId` is a slug pointing at a content file in `src/content/modules/`.
// There's intentionally no foreign key: content lives in git, not the DB.
// If a module is renamed or removed the Result row remains, with `module`
// resolution returning null at read time.
model Result {
  id        String   @id @default(uuid())
  score     Int
  total     Int
  time      Int      // seconds
  mistakes  Json     // array of mistake details (prompt/answer denormalized at save time)
  // Full denormalized response log: every question's prompt + correct answer
  // + user answer + correctness flag. Stored verbatim so reviews still work
  // after the source question bank changes. Null on legacy rows.
  responses Json?
  level     Int?     // difficulty bucket for leveled modules (e.g. fractions); null otherwise
  createdAt DateTime @default(now())
  userId    String
  moduleId  String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
