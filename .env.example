# Copy to `.env` for local development. Never commit secrets.
# In production, these are set in the Coolify dashboard.

# PostgreSQL connection string
# Local dev points at the shared-postgres stack in ~/Dev/lr15a/local.
# - npm run dev:           postgresql://polymath_user:polymath-dev@localhost:5432/polymath_db
# - ./deploy-test.sh:      postgresql://polymath_user:polymath-dev@host.docker.internal:5432/polymath_db
DATABASE_URL=""

# Auth.js v5 — full URL of the deployed app (no trailing slash)
AUTH_URL="http://localhost:3000"

# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Admin account bootstrapped by `npm run db:seed` (dev + first prod deploy)
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
