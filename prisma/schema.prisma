// Prisma schema for Polymath learning platform

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// Auth.js Required Models
// ============================================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  role          String    @default("STUDENT") // "ADMIN" or "STUDENT"
  accounts      Account[]
  sessions      Session[]
  results       Result[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// Polymath Application Models
// ============================================

// Module - container for quiz items (e.g., "English Plurals", "Algebra 1")
model Module {
  id          String   @id @default(uuid())
  title       String
  subject     String   // "LANGUAGE", "MATH", "LOGIC"
  description String
  items       Item[]
  results     Result[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ItemType enum - determines which renderer to use
enum ItemType {
  TEXT      // Simple Q&A (vocabulary, translations)
  MATH_EQ   // LaTeX formulas (algebra)
  GEOMETRY  // SVG shapes
}

// Item - individual quiz question with flexible JSON content
model Item {
  id        String   @id @default(uuid())
  moduleId  String
  type      ItemType @default(TEXT)
  content   Json     // Flexible payload based on ItemType
  module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Result - tracks quiz performance for analytics
model Result {
  id        String   @id @default(uuid())
  score     Int
  total     Int
  time      Int      // seconds
  mistakes  Json     // array of mistake details
  createdAt DateTime @default(now())
  userId    String
  moduleId  String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}
