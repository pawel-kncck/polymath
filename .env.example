# Copy to `.env` for local development. Never commit secrets.
# In production, these are set in the Coolify dashboard.

# PostgreSQL connection string
DATABASE_URL=""

# Auth.js v5 — full URL of the deployed app (no trailing slash)
AUTH_URL="http://localhost:3000"

# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Admin account bootstrapped by `npm run db:seed` (dev + first prod deploy)
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
